      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap');\n\n  :root {\n    --color-primary: #863BFF;\n    --color-secondary: #47BFFF;\n    --color-bg: #0F1419;\n    --color-surface: rgba(26, 31, 38, 0.4);\n    --font-sans: 'Inter', sans-serif;\n    --font-display: 'Inter', sans-serif; /* Fallback for Cal Sans */\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: #FAFAFA;\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow: hidden;\n  }\n\n  .glass-card {\n    background: var(--color-surface);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n  }\n\n  .diagonal-split {\n    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 65%);\n  }\n\n  .btn-google {\n    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  \n  .btn-google:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 0 20px rgba(134, 59, 255, 0.4);\n  }\n\n  .btn-google:active {\n    transform: scale(0.97);\n  }\n\n  .bolt-gradient {\n    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n</style>\n\n<div class=\"relative min-h-screen flex items-center justify-center overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"absolute inset-0 z-0\" data-kid=\"2\">\n    <div class=\"absolute inset-0 bg-black/60 z-10\" data-kid=\"3\"></div>\n    <video src=\"https://videos.pexels.com/video-files/34250818/14513409_640_360_24fps.mp4\" poster=\"https://images.pexels.com/videos/34250818/abstract-background-cg-cg-art-looping-34250818.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover diagonal-split\" data-kid=\"4\"></video>\n  </div>\n\n  \n  <div class=\"absolute top-10 right-10 w-64 h-64 bg-primary/20 blur-[100px] rounded-full animate-pulse\" data-kid=\"5\"></div>\n  <div class=\"absolute bottom-10 left-10 w-96 h-96 bg-secondary/10 blur-[120px] rounded-full\" data-kid=\"6\"></div>\n\n  \n  <div class=\"relative z-20 w-full max-w-xl px-6 text-center\" data-kid=\"7\">\n    \n    <div id=\"logo\" class=\"mb-12 flex justify-center\" data-kid=\"8\">\n      <div class=\"w-16 h-16 bg-gradient-to-br from-[#863BFF] to-[#47BFFF] rounded-xl flex items-center justify-center shadow-lg shadow-primary/30\" data-kid=\"9\">\n        <svg viewBox=\"0 0 48 46\" class=\"w-10 h-10 fill-white\" data-kid=\"10\">\n          <path d=\"M25.946 44.938c-.664.845-2.021.375-2.021-.698V33.937a2.26 2.26 0 0 0-2.262-2.262H10.287c-.92 0-1.456-1.04-.92-1.788l7.48-10.471c1.07-1.497 0-3.578-1.842-3.578H1.237c-.92 0-1.456-1.04-.92-1.788L10.013.474c.214-.297.556-.474.92-.474h28.894c.92 0 1.456 1.04.92 1.788l-7.48 10.471c-1.07 1.498 0 3.579 1.842 3.579h11.377c.943 0 1.473 1.088.89 1.83L25.947 44.94z\" data-kid=\"11\"></path>\n        </svg>\n      </div>\n    </div>\n\n    \n    <h1 id=\"headline\" class=\"text-7xl font-bold tracking-tight mb-4 leading-none\" data-kid=\"12\">\n      Power Your <span class=\"bolt-gradient\" data-kid=\"13\">Wealth</span>\n    </h1>\n    <p id=\"subtext\" class=\"text-xl text-[#A1A8B3] mb-12 max-w-md mx-auto\" data-kid=\"14\">\n      Bienvenido a JP-WALLET. Tus finanzas, simples, seguras y rápidas.\n    </p>\n\n    \n    <div id=\"login-card\" class=\"glass-card p-10 rounded-3xl border border-white/10\" data-kid=\"15\">\n      <h2 class=\"text-2xl font-semibold mb-8\" data-kid=\"16\">Ingresar a tu cuenta</h2>\n      \n      <button class=\"btn-google w-full bg-white text-black py-4 px-6 rounded-2xl font-bold flex items-center justify-center gap-4 group\" data-kid=\"17\">\n        <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" data-kid=\"18\">\n          <path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" fill=\"#4285F4\" data-kid=\"19\"></path>\n          <path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" fill=\"#34A853\" data-kid=\"20\"></path>\n          <path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z\" fill=\"#FBBC05\" data-kid=\"21\"></path>\n          <path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 12-4.53z\" fill=\"#EA4335\" data-kid=\"22\"></path>\n        </svg>\n        Continuar con Google\n      </button>\n\n      <p class=\"mt-8 text-sm text-[#6B7280]\" data-kid=\"23\">\n        Al continuar aceptás nuestros <a href=\"#\" class=\"text-primary hover:underline\" data-kid=\"24\">términos y condiciones</a>.\n      </p>\n    </div>\n\n    \n    <div id=\"footer\" class=\"mt-12 text-[#525866] text-xs font-mono uppercase tracking-widest\" data-kid=\"25\">\n      JP-DS Foundation v1.0.0 &copy; 2026\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"26\"></script>\n<script data-kid=\"27\">\n  window.addEventListener('load', () => {\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 1.2 }});\n    \n    tl.from(\"#logo\", { y: -50, opacity: 0 })\n      .from(\"#headline\", { y: 30, opacity: 0 }, \"-=0.8\")\n      .from(\"#subtext\", { y: 20, opacity: 0 }, \"-=0.8\")\n      .from(\"#login-card\", { scale: 0.95, opacity: 0, y: 30 }, \"-=0.8\")\n      .from(\"#footer\", { opacity: 0 }, \"-=0.4\");\n  });\n</script>",
