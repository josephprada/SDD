      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg: #FAFAFA;\n    --surface-1: #FFFFFF;\n    --surface-2: #F4F4F5;\n    --surface-3: #E4E4E7;\n    --text-primary: #0F1419;\n    --text-secondary: #525866;\n    --text-tertiary: #8B92A1;\n    --border: #E4E4E7;\n    --accent: #863BFF;\n    --accent-hover: #7E14FF;\n    --accent-blue: #47BFFF;\n    --radius-md: 12px;\n    --radius-full: 9999px;\n    --duration-base: 300ms;\n    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-display {\n    font-family: 'Inter', sans-serif; /* Fallback for Cal Sans */\n    font-weight: 700;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n  }\n\n  .gelatinous-depth {\n    box-shadow: \n      0 4px 6px -1px rgba(134, 59, 255, 0.05), \n      0 2px 4px -1px rgba(134, 59, 255, 0.03),\n      inset 0 1px 0 0 rgba(255, 255, 255, 0.5);\n  }\n\n  .diagonal-bg {\n    position: absolute;\n    top: -100px;\n    right: -50px;\n    width: 300px;\n    height: 300px;\n    background: linear-gradient(135deg, rgba(134, 59, 255, 0.1) 0%, rgba(71, 191, 255, 0.1) 100%);\n    clip-path: polygon(100% 0, 0% 100%, 100% 100%);\n    z-index: -1;\n  }\n\n  .bolt-shape {\n    clip-path: polygon(25% 0%, 100% 0%, 75% 45%, 100% 45%, 30% 100%, 45% 55%, 0% 55%);\n    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-blue) 100%);\n  }\n</style>\n\n<div class=\"relative min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <div class=\"diagonal-bg\" data-kid=\"2\"></div>\n\n  \n  <header class=\"sticky top-0 z-50 glass border-b border-[var(--border)] gelatinous-depth\" data-kid=\"3\">\n    <div class=\"h-16 px-5 flex items-center justify-between\" data-kid=\"4\">\n      \n      <div class=\"flex items-center gap-2\" data-kid=\"5\">\n        <div class=\"w-8 h-8 bolt-shape\" data-kid=\"6\"></div>\n        <span class=\"font-display text-lg tracking-tight\" data-kid=\"7\">JP-WALLET</span>\n      </div>\n\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"8\">\n        <button class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-[var(--surface-2)] transition-colors duration-200\" data-kid=\"9\">\n          <i class=\"ti ti-sun text-xl\" data-kid=\"10\"></i>\n        </button>\n        <button class=\"w-10 h-10 rounded-full border-2 border-[var(--accent)] p-0.5 overflow-hidden active:scale-95 transition-transform\" data-kid=\"11\">\n          <img src=\"https://i.pravatar.cc/100?u=jpwallet\" alt=\"User\" class=\"w-full h-full rounded-full object-cover\" data-kid=\"12\">\n        </button>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"flex-1 px-5 pt-8 pb-24\" data-kid=\"13\">\n    <div class=\"space-y-6\" data-kid=\"14\">\n      <div class=\"space-y-1\" data-kid=\"15\">\n        <h1 class=\"text-3xl font-display text-[var(--text-primary)]\" data-kid=\"16\">¡Hola, Juan!</h1>\n        <p class=\"text-[var(--text-secondary)]\" data-kid=\"17\">Tus finanzas se ven sólidas hoy.</p>\n      </div>\n\n      \n      <div class=\"relative overflow-hidden rounded-[var(--radius-md)] p-6 text-white gelatinous-depth\" style=\"background: linear-gradient(135deg, #863BFF 0%, #47BFFF 100%);\" data-kid=\"18\">\n        <div class=\"absolute top-0 right-0 p-4 opacity-20\" data-kid=\"19\">\n          <i class=\"ti ti-bolt text-6xl\" data-kid=\"20\"></i>\n        </div>\n        <p class=\"text-sm font-medium opacity-80 mb-1\" data-kid=\"21\">Balance Total</p>\n        <h2 class=\"text-4xl font-bold mb-4\" data-kid=\"22\">$12.450,00</h2>\n        <div class=\"flex items-center gap-2 bg-white/20 w-fit px-3 py-1 rounded-full text-xs\" data-kid=\"23\">\n          <i class=\"ti ti-arrow-up-right\" data-kid=\"24\"></i>\n          <span data-kid=\"25\">+4.2% este mes</span>\n        </div>\n      </div>\n\n      \n      <div class=\"space-y-4\" data-kid=\"26\">\n        <h3 class=\"font-semibold text-lg\" data-kid=\"27\">Actividad Reciente</h3>\n        <div class=\"space-y-3\" data-kid=\"28\">\n          <div class=\"p-4 rounded-[var(--radius-md)] bg-[var(--surface-1)] border border-[var(--border)] flex items-center justify-between\" data-kid=\"29\">\n            <div class=\"flex items-center gap-3\" data-kid=\"30\">\n              <div class=\"w-10 h-10 rounded-full bg-[var(--surface-2)] flex items-center justify-center\" data-kid=\"31\">\n                <i class=\"ti ti-shopping-cart text-[var(--accent)]\" data-kid=\"32\"></i>\n              </div>\n              <div data-kid=\"33\">\n                <p class=\"font-medium\" data-kid=\"34\">Starbucks</p>\n                <p class=\"text-xs text-[var(--text-tertiary)]\" data-kid=\"35\">Hace 2 horas</p>\n              </div>\n            </div>\n            <p class=\"font-semibold\" data-kid=\"36\">-$450,00</p>\n          </div>\n          <div class=\"p-4 rounded-[var(--radius-md)] bg-[var(--surface-1)] border border-[var(--border)] flex items-center justify-between\" data-kid=\"37\">\n            <div class=\"flex items-center gap-3\" data-kid=\"38\">\n              <div class=\"w-10 h-10 rounded-full bg-[var(--surface-2)] flex items-center justify-center\" data-kid=\"39\">\n                <i class=\"ti ti-transfer-in text-[var(--accent-blue)]\" data-kid=\"40\"></i>\n              </div>\n              <div data-kid=\"41\">\n                <p class=\"font-medium\" data-kid=\"42\">Transferencia</p>\n                <p class=\"text-xs text-[var(--text-tertiary)]\" data-kid=\"43\">Ayer</p>\n              </div>\n            </div>\n            <p class=\"font-semibold text-green-600\" data-kid=\"44\">+$2.500,00</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <nav class=\"fixed bottom-0 left-0 right-0 z-50 glass border-t border-[var(--border)] pb-safe shadow-[0_-4px_20px_rgba(0,0,0,0.03)]\" data-kid=\"45\">\n    <div class=\"h-16 px-4 flex items-center justify-between\" data-kid=\"46\">\n      \n      <a href=\"#\" class=\"flex flex-col items-center gap-1 min-w-[64px] relative\" data-kid=\"47\">\n        <div class=\"absolute -top-1 w-12 h-1 bg-[var(--accent)] rounded-b-full\" data-kid=\"48\"></div>\n        <i class=\"ti ti-home text-xl text-[var(--accent)]\" data-kid=\"49\"></i>\n        <span class=\"text-[10px] font-bold text-[var(--accent)]\" data-kid=\"50\">Inicio</span>\n      </a>\n      \n      <a href=\"#\" class=\"flex flex-col items-center gap-1 min-w-[64px] text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors\" data-kid=\"51\">\n        <i class=\"ti ti-arrows-left-right text-xl\" data-kid=\"52\"></i>\n        <span class=\"text-[10px] font-medium\" data-kid=\"53\">Transac.</span>\n      </a>\n\n      \n      <div class=\"relative -top-6\" data-kid=\"54\">\n        <button class=\"w-14 h-14 bolt-shape shadow-[0_8px_16px_rgba(134,59,255,0.4)] flex items-center justify-center text-white text-2xl active:scale-90 transition-transform\" data-kid=\"55\">\n          <i class=\"ti ti-plus\" data-kid=\"56\"></i>\n        </button>\n      </div>\n\n      <a href=\"#\" class=\"flex flex-col items-center gap-1 min-w-[64px] text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors\" data-kid=\"57\">\n        <i class=\"ti ti-chart-bar text-xl\" data-kid=\"58\"></i>\n        <span class=\"text-[10px] font-medium\" data-kid=\"59\">Reportes</span>\n      </a>\n\n      <a href=\"#\" class=\"flex flex-col items-center gap-1 min-w-[64px] text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors\" data-kid=\"60\">\n        <i class=\"ti ti-dots text-xl\" data-kid=\"61\"></i>\n        <span class=\"text-[10px] font-medium\" data-kid=\"62\">Más</span>\n      </a>\n    </div>\n  </nav>\n</div>",
