      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: #0F1419;\n    color: #FAFAFA;\n    margin: 0;\n    padding: 48px;\n  }\n\n  .font-display {\n    font-family: 'Inter', sans-serif;\n    font-weight: 800;\n    letter-spacing: -0.03em;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .glass-surface {\n    background: rgba(26, 31, 38, 0.4);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n  }\n\n  .btn-primary {\n    background-color: #863BFF;\n    color: white;\n    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .btn-primary:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 0 20px rgba(134, 59, 255, 0.4);\n  }\n  .btn-primary:active {\n    transform: scale(0.97);\n  }\n\n  .btn-secondary {\n    background-color: rgba(26, 31, 38, 0.6);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    color: #FAFAFA;\n    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .btn-secondary:hover {\n    transform: translateY(-4px);\n    border-color: #863BFF;\n  }\n  .btn-secondary:active {\n    transform: scale(0.97);\n  }\n\n  .btn-ghost {\n    background: transparent;\n    color: #A1A8B3;\n    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .btn-ghost:hover {\n    background: rgba(255, 255, 255, 0.05);\n    color: #FAFAFA;\n  }\n\n  .input-field {\n    background: rgba(26, 31, 38, 0.4);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .input-field:focus-within {\n    border-color: #863BFF;\n    box-shadow: 0 0 0 2px rgba(134, 59, 255, 0.2);\n  }\n\n  .avatar-mask {\n    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);\n  }\n\n  .spinner-dot {\n    width: 6px;\n    height: 6px;\n    background-color: #863BFF;\n    border-radius: 50%;\n    animation: bounce 1.4s infinite ease-in-out both;\n  }\n  .spinner-dot:nth-child(1) { animation-delay: -0.32s; }\n  .spinner-dot:nth-child(2) { animation-delay: -0.16s; }\n\n  @keyframes bounce {\n    0%, 80%, 100% { transform: scale(0); }\n    40% { transform: scale(1.0); }\n  }\n\n  .diagonal-bg {\n    background: linear-gradient(135deg, rgba(134, 59, 255, 0.1) 0%, transparent 100%);\n    clip-path: polygon(0 0, 100% 0, 100% 80%, 0 100%);\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n\n<div class=\"max-w-6xl mx-auto space-y-24\" data-kid=\"2\">\n  \n  <div class=\"space-y-4\" data-kid=\"3\">\n    <h1 class=\"text-6xl font-display text-transparent bg-clip-text bg-gradient-to-r from-[#863BFF] to-[#47BFFF]\" data-kid=\"4\">\n      JP-DS Foundation\n    </h1>\n    <p class=\"text-[#A1A8B3] text-lg max-w-2xl\" data-kid=\"5\">\n      Foundational design system components for JP-WALLET. Built with sharp geometry, gelatinous depth, and high-tactility interactions.\n    </p>\n  </div>\n\n  \n  <section class=\"space-y-8\" data-kid=\"6\">\n    <h2 class=\"text-2xl font-display border-b border-white/10 pb-4\" data-kid=\"7\">Buttons</h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-8\" data-kid=\"8\">\n      \n      <div class=\"space-y-6\" data-kid=\"9\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"10\">Primary</p>\n        <button class=\"btn-primary w-full py-3 px-6 rounded-lg font-medium\" data-kid=\"11\">Default</button>\n        <button class=\"btn-primary w-full py-3 px-6 rounded-lg font-medium shadow-[0_0_20px_rgba(134,59,255,0.4)] -translate-y-1\" data-kid=\"12\">Hover</button>\n        <button class=\"btn-primary w-full py-3 px-6 rounded-lg font-medium scale-95 opacity-90\" data-kid=\"13\">Pressed</button>\n        <button class=\"btn-primary w-full py-3 px-6 rounded-lg font-medium opacity-50 cursor-not-allowed\" data-kid=\"14\">Disabled</button>\n      </div>\n      \n      <div class=\"space-y-6\" data-kid=\"15\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"16\">Secondary</p>\n        <button class=\"btn-secondary w-full py-3 px-6 rounded-lg font-medium\" data-kid=\"17\">Default</button>\n        <button class=\"btn-secondary w-full py-3 px-6 rounded-lg font-medium border-[#863BFF] -translate-y-1\" data-kid=\"18\">Hover</button>\n        <button class=\"btn-secondary w-full py-3 px-6 rounded-lg font-medium scale-95\" data-kid=\"19\">Pressed</button>\n        <button class=\"btn-secondary w-full py-3 px-6 rounded-lg font-medium opacity-50 cursor-not-allowed\" data-kid=\"20\">Disabled</button>\n      </div>\n      \n      <div class=\"space-y-6\" data-kid=\"21\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"22\">Ghost</p>\n        <button class=\"btn-ghost w-full py-3 px-6 rounded-lg font-medium\" data-kid=\"23\">Default</button>\n        <button class=\"btn-ghost w-full py-3 px-6 rounded-lg font-medium bg-white/5 text-white\" data-kid=\"24\">Hover</button>\n        <button class=\"btn-ghost w-full py-3 px-6 rounded-lg font-medium scale-95\" data-kid=\"25\">Pressed</button>\n        <button class=\"btn-ghost w-full py-3 px-6 rounded-lg font-medium opacity-30 cursor-not-allowed\" data-kid=\"26\">Disabled</button>\n      </div>\n      \n      <div class=\"space-y-6\" data-kid=\"27\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"28\">Special States</p>\n        <button class=\"btn-primary w-full py-3 px-6 rounded-lg font-medium flex items-center justify-center gap-2\" data-kid=\"29\">\n          <div class=\"flex gap-1\" data-kid=\"30\">\n            <div class=\"spinner-dot bg-white\" data-kid=\"31\"></div>\n            <div class=\"spinner-dot bg-white\" data-kid=\"32\"></div>\n            <div class=\"spinner-dot bg-white\" data-kid=\"33\"></div>\n          </div>\n        </button>\n        <button class=\"bg-[#EF4444] text-white w-full py-3 px-6 rounded-lg font-medium flex items-center justify-center gap-2\" data-kid=\"34\">\n          <i class=\"ti ti-alert-circle\" data-kid=\"35\"></i> Error\n        </button>\n        <button class=\"bg-[#10B981] text-white w-full py-3 px-6 rounded-lg font-medium flex items-center justify-center gap-2\" data-kid=\"36\">\n          <i class=\"ti ti-check\" data-kid=\"37\"></i> Success\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"38\">\n    <h2 class=\"text-2xl font-display border-b border-white/10 pb-4\" data-kid=\"39\">Form Inputs</h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12\" data-kid=\"40\">\n      \n      <div class=\"space-y-2\" data-kid=\"41\">\n        <label class=\"text-xs text-[#A1A8B3] ml-1\" data-kid=\"42\">Email Address</label>\n        <div class=\"input-field rounded-lg px-4 py-3\" data-kid=\"43\">\n          <input type=\"text\" placeholder=\"name@company.com\" class=\"bg-transparent w-full outline-hidden text-sm placeholder:text-[#525866]\" data-kid=\"44\">\n        </div>\n      </div>\n      \n      <div class=\"space-y-2\" data-kid=\"45\">\n        <label class=\"text-xs text-[#863BFF] ml-1\" data-kid=\"46\">Focus State</label>\n        <div class=\"input-field rounded-lg px-4 py-3 border-[#863BFF] shadow-[0_0_0_2px_rgba(134,59,255,0.2)]\" data-kid=\"47\">\n          <input type=\"text\" value=\"john@doe.com\" class=\"bg-transparent w-full outline-hidden text-sm\" data-kid=\"48\">\n        </div>\n      </div>\n      \n      <div class=\"space-y-2\" data-kid=\"49\">\n        <label class=\"text-xs text-[#EF4444] ml-1\" data-kid=\"50\">Error State</label>\n        <div class=\"input-field rounded-lg px-4 py-3 border-[#EF4444] bg-red-500/5\" data-kid=\"51\">\n          <input type=\"text\" value=\"invalid-email\" class=\"bg-transparent w-full outline-hidden text-sm\" data-kid=\"52\">\n        </div>\n        <p class=\"text-[10px] text-[#EF4444] ml-1\" data-kid=\"53\">Please enter a valid email address.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"54\">\n    <h2 class=\"text-2xl font-display border-b border-white/10 pb-4\" data-kid=\"55\">Avatars & Icon Buttons</h2>\n    <div class=\"flex flex-wrap items-end gap-16\" data-kid=\"56\">\n      \n      <div class=\"space-y-6\" data-kid=\"57\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"58\">Sharp Avatars</p>\n        <div class=\"flex items-center gap-6\" data-kid=\"59\">\n          <div class=\"avatar-mask w-20 h-20 bg-gradient-to-br from-[#863BFF] to-[#47BFFF] p-[1px]\" data-kid=\"60\">\n             <img src=\"https://i.pravatar.cc/150?u=jpwallet1\" class=\"avatar-mask w-full h-full object-cover\" data-kid=\"61\">\n          </div>\n          <div class=\"avatar-mask w-14 h-14 bg-[#1A1F26] flex items-center justify-center border border-white/10\" data-kid=\"62\">\n             <span class=\"font-display text-xl text-[#863BFF]\" data-kid=\"63\">JD</span>\n          </div>\n          <div class=\"avatar-mask w-10 h-10 bg-[#242A33] flex items-center justify-center border border-white/10\" data-kid=\"64\">\n             <i class=\"ti ti-user text-[#A1A8B3]\" data-kid=\"65\"></i>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"space-y-6\" data-kid=\"66\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"67\">Icon Buttons</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"68\">\n          <button class=\"btn-secondary p-3 rounded-lg\" data-kid=\"69\"><i class=\"ti ti-sun text-xl\" data-kid=\"70\"></i></button>\n          <button class=\"btn-primary p-3 rounded-lg shadow-lg\" data-kid=\"71\"><i class=\"ti ti-plus text-xl\" data-kid=\"72\"></i></button>\n          <button class=\"btn-secondary p-3 rounded-lg opacity-50\" data-kid=\"73\"><i class=\"ti ti-settings text-xl\" data-kid=\"74\"></i></button>\n          <button class=\"btn-ghost p-3 rounded-lg\" data-kid=\"75\"><i class=\"ti ti-bell text-xl\" data-kid=\"76\"></i></button>\n        </div>\n      </div>\n      \n      <div class=\"space-y-6\" data-kid=\"77\">\n        <p class=\"text-xs uppercase tracking-widest text-[#A1A8B3]\" data-kid=\"78\">Monospace Data</p>\n        <div class=\"space-y-2\" data-kid=\"79\">\n          <p class=\"font-mono text-3xl font-bold text-[#FAFAFA]\" data-kid=\"80\">$12,450.00</p>\n          <p class=\"font-mono text-sm text-[#10B981]\" data-kid=\"81\">+ 12.5% vs last month</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"82\">\n    <h2 class=\"text-2xl font-display border-b border-white/10 pb-4\" data-kid=\"83\">Geometric Motifs</h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"84\">\n      <div class=\"glass-surface h-48 rounded-2xl relative overflow-hidden group\" data-kid=\"85\">\n        <div class=\"absolute inset-0 diagonal-bg opacity-30 group-hover:opacity-50 transition-opacity\" data-kid=\"86\"></div>\n        <div class=\"absolute top-6 left-6 space-y-2\" data-kid=\"87\">\n          <h3 class=\"font-display text-xl\" data-kid=\"88\">Layered Depth</h3>\n          <p class=\"text-sm text-[#A1A8B3]\" data-kid=\"89\">Glassmorphism with backdrop blur and sharp masks.</p>\n        </div>\n      </div>\n      <div class=\"glass-surface h-48 rounded-2xl relative overflow-hidden flex items-center justify-center\" data-kid=\"90\">\n         <div class=\"flex gap-4\" data-kid=\"91\">\n           <div class=\"w-12 h-12 avatar-mask bg-[#863BFF]/20 flex items-center justify-center\" data-kid=\"92\">\n             <i class=\"ti ti-bolt text-[#863BFF] text-2xl\" data-kid=\"93\"></i>\n           </div>\n           <div class=\"w-12 h-12 avatar-mask bg-[#47BFFF]/20 flex items-center justify-center\" data-kid=\"94\">\n             <i class=\"ti ti-rocket text-[#47BFFF] text-2xl\" data-kid=\"95\"></i>\n           </div>\n           <div class=\"w-12 h-12 avatar-mask bg-[#FAFAFA]/10 flex items-center justify-center\" data-kid=\"96\">\n             <i class=\"ti ti-shield-check text-[#FAFAFA] text-2xl\" data-kid=\"97\"></i>\n           </div>\n         </div>\n      </div>\n    </div>\n  </section>\n</div>",
