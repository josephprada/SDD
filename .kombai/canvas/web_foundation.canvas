      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap');\n\n  :root {\n    --brand-purple: #863BFF;\n    --brand-blue: #47BFFF;\n    --bg-main: #FAFAFA;\n    --text-primary: #0F1419;\n    --text-secondary: #525866;\n    --glass-bg: rgba(255, 255, 255, 0.45);\n    --glass-border: rgba(255, 255, 255, 0.3);\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: var(--text-primary);\n  }\n\n  .font-display {\n    font-family: 'Inter', sans-serif;\n    font-weight: 800;\n    letter-spacing: -0.03em;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid var(--glass-border);\n  }\n\n  .sidebar-link-active {\n    background: var(--brand-purple);\n    color: white;\n    box-shadow: 0 10px 15px -3px rgba(134, 59, 255, 0.2), 0 4px 6px -4px rgba(134, 59, 255, 0.2);\n  }\n\n  .diagonal-split {\n    position: absolute;\n    top: 0;\n    right: 0;\n    width: 100%;\n    height: 70vh;\n    background: linear-gradient(135deg, rgba(134, 59, 255, 0.05) 0%, rgba(71, 191, 255, 0.05) 100%);\n    clip-path: polygon(0 0, 100% 0, 100% 40%, 0 100%);\n    z-index: -1;\n    pointer-events: none;\n  }\n\n  .btn-press:active {\n    transform: scale(0.97);\n  }\n\n  .hover-lift:hover {\n    transform: translateY(-4px);\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(0, 0, 0, 0.05);\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"relative min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <div class=\"diagonal-split\" data-kid=\"2\"></div>\n  <div class=\"absolute top-[-10%] left-[-5%] w-[40%] h-[40%] bg-[#863BFF]/5 blur-[120px] rounded-full z-[-1]\" data-kid=\"3\"></div>\n\n  \n  <header class=\"h-16 glass sticky top-0 z-50 px-6 flex items-center justify-between border-b border-gray-200/30\" data-kid=\"4\">\n    <div class=\"flex items-center gap-8\" data-kid=\"5\">\n      <a href=\"/\" class=\"flex items-center gap-2.5 group\" data-kid=\"6\">\n        <div class=\"w-8 h-8 flex items-center justify-center rounded-lg overflow-hidden transition-transform duration-300 group-hover:rotate-12\" data-kid=\"7\">\n          <img src=\"/api/local/images/public/favicon.svg\" alt=\"JP-WALLET\" class=\"w-full h-full object-contain\" data-kid=\"8\">\n        </div>\n        <span class=\"font-display text-xl tracking-tight\" data-kid=\"9\">JP-WALLET</span>\n      </a>\n\n      \n      <nav class=\"hidden md:flex items-center gap-1 ml-4\" data-kid=\"10\">\n        <a href=\"#\" class=\"px-4 py-2 text-sm font-medium rounded-lg bg-gray-100/50 text-gray-900\" data-kid=\"11\">Dashboard</a>\n        <a href=\"#\" class=\"px-4 py-2 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-white/50 transition-colors\" data-kid=\"12\">Transacciones</a>\n        <a href=\"#\" class=\"px-4 py-2 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-white/50 transition-colors\" data-kid=\"13\">Cuentas</a>\n        <a href=\"#\" class=\"px-4 py-2 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-white/50 transition-colors\" data-kid=\"14\">Reportes</a>\n        <a href=\"#\" class=\"px-4 py-2 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-white/50 transition-colors\" data-kid=\"15\">Configuración</a>\n      </nav>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"16\">\n      \n      <div class=\"relative hidden lg:block\" data-kid=\"17\">\n        <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"18\"></i>\n        <input type=\"text\" placeholder=\"Buscar...\" class=\"pl-10 pr-4 py-2 glass rounded-full text-sm w-48 focus:w-64 transition-all duration-300 focus:outline-hidden focus:ring-2 focus:ring-[#863BFF]/20\" data-kid=\"19\">\n      </div>\n\n      \n      <div class=\"flex items-center gap-2\" data-kid=\"20\">\n        <button class=\"p-2 glass rounded-xl hover:bg-white transition-colors btn-press\" data-kid=\"21\">\n          <i class=\"ti ti-sun text-lg\" data-kid=\"22\"></i>\n        </button>\n        <button class=\"p-2 glass rounded-xl hover:bg-white transition-colors btn-press relative\" data-kid=\"23\">\n          <i class=\"ti ti-bell text-lg\" data-kid=\"24\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white\" data-kid=\"25\"></span>\n        </button>\n      </div>\n\n      \n      <button class=\"flex items-center gap-2 p-1.5 glass rounded-full border-gray-200/50 hover:bg-white transition-all btn-press ml-2\" data-kid=\"26\">\n        <div class=\"w-7 h-7 rounded-full bg-linear-to-br from-[#863BFF] to-[#47BFFF] flex items-center justify-center text-[10px] font-bold text-white shadow-inner\" data-kid=\"27\">\n          JP\n        </div>\n        <i class=\"ti ti-chevron-down text-xs text-gray-400 mr-1\" data-kid=\"28\"></i>\n      </button>\n    </div>\n  </header>\n\n  <div class=\"flex flex-1 overflow-hidden\" data-kid=\"29\">\n    \n    <aside class=\"w-64 glass z-40 border-r border-gray-200/30 flex flex-col shrink-0\" data-kid=\"30\">\n      <div class=\"flex-1 py-8 px-4 space-y-8 overflow-y-auto\" data-kid=\"31\">\n        \n        <div class=\"space-y-1.5\" data-kid=\"32\">\n          <p class=\"px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3\" data-kid=\"33\">Principal</p>\n          <a href=\"#\" class=\"sidebar-link-active flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm transition-all\" data-kid=\"34\">\n            <i class=\"ti ti-smart-home text-lg\" data-kid=\"35\"></i>\n            <span class=\"font-medium\" data-kid=\"36\">Inicio</span>\n          </a>\n          <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-500 hover:text-gray-900 hover:bg-white/60 transition-all group\" data-kid=\"37\">\n            <i class=\"ti ti-building-bank text-lg text-gray-400 group-hover:text-[#863BFF]\" data-kid=\"38\"></i>\n            <span class=\"font-medium\" data-kid=\"39\">Mis Cuentas</span>\n          </a>\n          <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-500 hover:text-gray-900 hover:bg-white/60 transition-all group\" data-kid=\"40\">\n            <i class=\"ti ti-receipt text-lg text-gray-400 group-hover:text-[#863BFF]\" data-kid=\"41\"></i>\n            <span class=\"font-medium\" data-kid=\"42\">Movimientos</span>\n          </a>\n        </div>\n\n        \n        <div class=\"space-y-1.5\" data-kid=\"43\">\n          <p class=\"px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3\" data-kid=\"44\">Análisis</p>\n          <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-500 hover:text-gray-900 hover:bg-white/60 transition-all group\" data-kid=\"45\">\n            <i class=\"ti ti-chart-dots text-lg text-gray-400 group-hover:text-[#863BFF]\" data-kid=\"46\"></i>\n            <span class=\"font-medium\" data-kid=\"47\">Estadísticas</span>\n          </a>\n          <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-500 hover:text-gray-900 hover:bg-white/60 transition-all group\" data-kid=\"48\">\n            <i class=\"ti ti-target-arrow text-lg text-gray-400 group-hover:text-[#863BFF]\" data-kid=\"49\"></i>\n            <span class=\"font-medium\" data-kid=\"50\">Presupuesto</span>\n          </a>\n        </div>\n\n        \n        <div class=\"space-y-1.5\" data-kid=\"51\">\n          <p class=\"px-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3\" data-kid=\"52\">Soporte</p>\n          <a href=\"#\" class=\"flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-500 hover:text-gray-900 hover:bg-white/60 transition-all group\" data-kid=\"53\">\n            <i class=\"ti ti-help-circle text-lg text-gray-400 group-hover:text-[#863BFF]\" data-kid=\"54\"></i>\n            <span class=\"font-medium\" data-kid=\"55\">Centro de Ayuda</span>\n          </a>\n        </div>\n      </div>\n\n      \n      <div class=\"p-4 m-4 glass rounded-2xl border-[#863BFF]/20 bg-linear-to-br from-white/40 to-[#863BFF]/5 relative overflow-hidden group\" data-kid=\"56\">\n        <div class=\"absolute -right-4 -bottom-4 w-20 h-20 bg-[#863BFF]/10 rounded-full blur-xl group-hover:scale-150 transition-transform duration-700\" data-kid=\"57\"></div>\n        <div class=\"relative z-10 space-y-3\" data-kid=\"58\">\n          <p class=\"text-xs font-bold text-[#863BFF]\" data-kid=\"59\">Pro Plan</p>\n          <p class=\"text-xs text-gray-500 leading-relaxed\" data-kid=\"60\">Obtén análisis detallados y límites extendidos.</p>\n          <button class=\"w-full py-2 bg-white rounded-lg text-[10px] font-bold text-gray-900 shadow-sm border border-gray-100 hover:shadow-md transition-shadow\" data-kid=\"61\">Actualizar ahora</button>\n        </div>\n      </div>\n    </aside>\n\n    \n    <main class=\"flex-1 overflow-y-auto p-10 relative\" data-kid=\"62\">\n      <div class=\"max-w-6xl mx-auto space-y-10\" data-kid=\"63\">\n        \n        <nav class=\"flex text-xs font-medium text-gray-400 gap-2 items-center\" data-kid=\"64\">\n          <a href=\"#\" class=\"hover:text-gray-600\" data-kid=\"65\">App</a>\n          <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"66\"></i>\n          <span class=\"text-gray-900\" data-kid=\"67\">Dashboard</span>\n        </nav>\n\n        \n        <div class=\"space-y-4\" data-kid=\"68\">\n          <h1 class=\"text-5xl font-display leading-tight text-gray-900\" data-kid=\"69\">Potencia tu <span class=\"text-transparent bg-clip-text bg-linear-to-r from-[#863BFF] to-[#47BFFF]\" data-kid=\"70\">patrimonio</span>.</h1>\n          <p class=\"text-lg text-gray-500 max-w-2xl\" data-kid=\"71\">Gestiona tus finanzas con la precisión de un rayo y la claridad de un cristal. Aquí tienes tu resumen financiero hoy.</p>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"72\">\n          \n          <div class=\"glass p-8 rounded-3xl hover-lift transition-all duration-300 shadow-xl shadow-black/[0.02] border-[#863BFF]/10 group\" data-kid=\"73\">\n            <div class=\"flex justify-between items-start mb-6\" data-kid=\"74\">\n              <div class=\"w-12 h-12 glass rounded-2xl flex items-center justify-center text-[#863BFF] bg-white/60\" data-kid=\"75\">\n                <i class=\"ti ti-wallet text-2xl\" data-kid=\"76\"></i>\n              </div>\n              <div class=\"px-2.5 py-1 rounded-full bg-green-100/50 text-green-600 text-[10px] font-bold border border-green-100 flex items-center gap-1\" data-kid=\"77\">\n                <i class=\"ti ti-trending-up\" data-kid=\"78\"></i> +12.4%\n              </div>\n            </div>\n            <p class=\"text-sm font-medium text-gray-400 mb-1\" data-kid=\"79\">Balance Total</p>\n            <h3 class=\"text-3xl font-mono font-bold tracking-tight\" data-kid=\"80\">$42,850.<span class=\"text-lg opacity-50\" data-kid=\"81\">60</span></h3>\n            <div class=\"mt-8 pt-6 border-t border-gray-100/50 flex items-center justify-between\" data-kid=\"82\">\n              <span class=\"text-[10px] font-bold text-gray-400 uppercase tracking-wider\" data-kid=\"83\">Ver detalles</span>\n              <button class=\"w-8 h-8 rounded-full glass flex items-center justify-center text-gray-400 group-hover:text-[#863BFF] group-hover:translate-x-1 transition-all\" data-kid=\"84\">\n                <i class=\"ti ti-arrow-right text-lg\" data-kid=\"85\"></i>\n              </button>\n            </div>\n          </div>\n\n          \n          <div class=\"glass p-8 rounded-3xl hover-lift transition-all duration-300 shadow-xl shadow-black/[0.02] border-[#47BFFF]/10 group\" data-kid=\"86\">\n            <div class=\"flex justify-between items-start mb-6\" data-kid=\"87\">\n              <div class=\"w-12 h-12 glass rounded-2xl flex items-center justify-center text-[#47BFFF] bg-white/60\" data-kid=\"88\">\n                <i class=\"ti ti-chart-line text-2xl\" data-kid=\"89\"></i>\n              </div>\n              <div class=\"px-2.5 py-1 rounded-full bg-blue-100/50 text-blue-600 text-[10px] font-bold border border-blue-100 flex items-center gap-1\" data-kid=\"90\">\n                En meta\n              </div>\n            </div>\n            <p class=\"text-sm font-medium text-gray-400 mb-1\" data-kid=\"91\">Ahorros Mensuales</p>\n            <h3 class=\"text-3xl font-mono font-bold tracking-tight\" data-kid=\"92\">$8,210.<span class=\"text-lg opacity-50\" data-kid=\"93\">00</span></h3>\n            <div class=\"mt-8 pt-6 border-t border-gray-100/50 flex items-center justify-between\" data-kid=\"94\">\n              <span class=\"text-[10px] font-bold text-gray-400 uppercase tracking-wider\" data-kid=\"95\">Metas de ahorro</span>\n              <button class=\"w-8 h-8 rounded-full glass flex items-center justify-center text-gray-400 group-hover:text-[#47BFFF] group-hover:translate-x-1 transition-all\" data-kid=\"96\">\n                <i class=\"ti ti-arrow-right text-lg\" data-kid=\"97\"></i>\n              </button>\n            </div>\n          </div>\n\n          \n          <div class=\"p-8 rounded-3xl relative overflow-hidden group shadow-2xl shadow-[#863BFF]/10\" data-kid=\"98\">\n            <div class=\"absolute inset-0 bg-linear-to-br from-[#863BFF] to-[#47BFFF] z-0 transition-transform duration-500 group-hover:scale-105\" data-kid=\"99\"></div>\n            <div class=\"absolute -right-4 -top-4 w-32 h-32 bg-white/10 rounded-full blur-2xl\" data-kid=\"100\"></div>\n            <div class=\"absolute -left-4 -bottom-4 w-40 h-40 bg-black/10 rounded-full blur-2xl\" data-kid=\"101\"></div>\n            \n            <div class=\"relative z-10 h-full flex flex-col justify-between text-white\" data-kid=\"102\">\n              <div class=\"flex justify-between items-start\" data-kid=\"103\">\n                <div class=\"w-10 h-10 bg-white/20 backdrop-blur-md rounded-xl flex items-center justify-center\" data-kid=\"104\">\n                  <i class=\"ti ti-bolt text-xl\" data-kid=\"105\"></i>\n                </div>\n                <span class=\"text-[10px] font-bold tracking-widest uppercase opacity-80\" data-kid=\"106\">Próximo Pago</span>\n              </div>\n              \n              <div class=\"mt-8\" data-kid=\"107\">\n                <p class=\"text-sm font-medium opacity-80 mb-1\" data-kid=\"108\">Servicios Cloud</p>\n                <h3 class=\"text-4xl font-mono font-bold tracking-tighter\" data-kid=\"109\">-$24.90</h3>\n                <p class=\"text-[10px] mt-2 opacity-60\" data-kid=\"110\">En 3 días (Vencimiento)</p>\n              </div>\n\n              <button class=\"mt-8 w-full py-3 bg-white text-[#863BFF] rounded-xl text-xs font-bold hover:bg-opacity-90 transition-all btn-press\" data-kid=\"111\">\n                Programar pago\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </main>\n  </div>\n</div>\n\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"112\">",
