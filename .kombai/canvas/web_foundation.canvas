    "var_c68aaf2c608b": {
      "type": "variant",
      "label": "App Shell - Mobile (Dark)",
      "parentId": "var_d644c226a051",
      "themeId": null,
      "rect": {
        "x": 475,
        "y": 0,
        "w": 375,
        "h": 812
