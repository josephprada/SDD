      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n  @font-face {\n    font-family: 'Cal Sans';\n    src: url('https://cdn.jsdelivr.net/gh/CalSans-org/CalSans@main/fonts/webfonts/CalSans-SemiBold.woff2') format('woff2');\n  }\n\n  :root {\n    --bg: #0F1419;\n    --surface-1: rgba(26, 31, 38, 0.6);\n    --accent: #07FBA2;\n    --accent-dark: #159563;\n    --text-primary: #FAFAFA;\n    --text-secondary: #A1A8B3;\n    --text-tertiary: #6B7280;\n    --border: rgba(47, 55, 66, 0.5);\n    \n    --duration-base: 0.3s;\n    --duration-slow: 0.5s;\n    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow: hidden;\n    height: 100vh;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .diagonal-bg {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(135deg, rgba(7, 251, 162, 0.05) 0%, rgba(15, 20, 25, 1) 50%);\n    z-index: -1;\n  }\n\n  .bolt-mask {\n    position: absolute;\n    top: -10%;\n    right: -5%;\n    width: 60%;\n    height: 120%;\n    background: linear-gradient(160deg, var(--accent) 0%, transparent 70%);\n    opacity: 0.08;\n    clip-path: polygon(40% 0%, 100% 0%, 70% 50%, 100% 50%, 30% 100%, 50% 100%, 20% 50%, 0% 50%);\n    z-index: -1;\n  }\n\n  .login-card {\n    background: var(--surface-1);\n    backdrop-filter: blur(32px);\n    border: 1px solid var(--border);\n    border-radius: 24px;\n    padding: 48px;\n    width: 100%;\n    max-width: 480px;\n    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(7, 251, 162, 0.05);\n    text-align: center;\n    position: relative;\n    z-index: 10;\n  }\n\n  .headline {\n    font-family: 'Cal Sans', sans-serif;\n    font-size: 64px;\n    line-height: 1.1;\n    margin-bottom: 16px;\n    background: linear-gradient(to bottom right, var(--accent), var(--accent-dark));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: -0.02em;\n  }\n\n  .google-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    width: 100%;\n    padding: 16px;\n    background-color: var(--accent);\n    color: #0F1419;\n    border-radius: 12px;\n    font-weight: 600;\n    font-size: 16px;\n    border: none;\n    cursor: pointer;\n    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s ease;\n    margin-top: 32px;\n  }\n\n  .google-btn:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 8px 24px rgba(7, 251, 162, 0.3);\n  }\n\n  .google-btn:active {\n    transform: translateY(-2px) scale(0.97);\n  }\n\n  .logo-container {\n    margin-bottom: 40px;\n    display: flex;\n    justify-content: center;\n  }\n\n  .logo-img {\n    width: 80px;\n    height: 80px;\n  }\n\n  .footer-text {\n    margin-top: 24px;\n    color: var(--text-tertiary);\n    font-size: 12px;\n  }\n</style>\n\n<div class=\"diagonal-bg\" data-kid=\"1\"></div>\n<div class=\"bolt-mask\" data-kid=\"2\"></div>\n\n<div class=\"flex flex-col items-center justify-center min-h-screen px-6\" data-kid=\"3\">\n  \n  <div id=\"brand\" class=\"mb-12 text-center opacity-0\" data-kid=\"4\">\n    <div class=\"logo-container\" data-kid=\"5\">\n      <img src=\"/api/local/images/public/icon.svg\" alt=\"JP-WALLET Bolt\" class=\"logo-img\" data-kid=\"6\">\n    </div>\n    <h1 class=\"headline\" data-kid=\"7\">Power Your Wealth</h1>\n    <p class=\"text-xl text-[var(--text-secondary)] max-w-lg mx-auto\" data-kid=\"8\">\n      Gestioná tus activos con la velocidad del rayo.\n    </p>\n  </div>\n\n  \n  <div id=\"login-card\" class=\"login-card opacity-0\" data-kid=\"9\">\n    <h2 class=\"text-2xl font-bold mb-2\" data-kid=\"10\">Bienvenido</h2>\n    <p class=\"text-[var(--text-secondary)] mb-8\" data-kid=\"11\">Ingresá a tu billetera para continuar.</p>\n    \n    <button class=\"google-btn\" data-kid=\"12\">\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\" data-kid=\"13\">\n        <path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" data-kid=\"14\"></path>\n        <path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" data-kid=\"15\"></path>\n        <path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z\" data-kid=\"16\"></path>\n        <path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z\" data-kid=\"17\"></path>\n      </svg>\n      Continuar con Google\n    </button>\n\n    <div class=\"footer-text\" data-kid=\"18\">\n      Al continuar, aceptás nuestros términos y condiciones.\n    </div>\n  </div>\n\n  <div id=\"footer-links\" class=\"mt-12 flex gap-6 text-sm text-[var(--text-tertiary)] opacity-0\" data-kid=\"19\">\n    <a href=\"#\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"20\">Seguridad</a>\n    <a href=\"#\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"21\">Soporte</a>\n    <a href=\"#\" class=\"hover:text-[var(--accent)] transition-colors\" data-kid=\"22\">Privacidad</a>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"23\"></script>\n<script data-kid=\"24\">\n  window.addEventListener('load', () => {\n    const tl = gsap.timeline({ defaults: { ease: \"power4.out\", duration: 1 } });\n\n    tl.to(\"#brand\", { opacity: 1, y: 0, from: { y: 40 } })\n      .to(\"#login-card\", { opacity: 1, scale: 1, from: { scale: 0.95 }, duration: 0.8 }, \"-=0.6\")\n      .to(\"#footer-links\", { opacity: 1 }, \"-=0.4\");\n  });\n</script>",
