      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg: #0F1419;\n    --surface-1: #1A1F26;\n    --surface-2: #242A33;\n    --surface-3: #2F3742;\n    --text-primary: #FAFAFA;\n    --text-secondary: #A1A8B3;\n    --text-tertiary: #6B7280;\n    --border: #2F3742;\n    --accent: #07FBA2;\n    --accent-hover: #159563;\n    --font-sans: 'Inter', system-ui, sans-serif;\n    --font-display: 'Inter', system-ui, sans-serif; /* Fallback for Cal Sans */\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    margin: 0;\n    font-family: var(--font-sans);\n    background-color: var(--bg);\n    color: var(--text-primary);\n    overflow-x: hidden;\n  }\n\n  .glass {\n    background: rgba(26, 31, 38, 0.6);\n    backdrop-filter: blur(32px);\n    -webkit-backdrop-filter: blur(32px);\n  }\n\n  .diagonal-bg {\n    position: fixed;\n    top: 0;\n    right: 0;\n    width: 60%;\n    height: 100%;\n    background: linear-gradient(135deg, rgba(7, 251, 162, 0.05) 0%, rgba(15, 20, 25, 0) 70%);\n    clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);\n    z-index: -1;\n  }\n\n  .nav-item-active {\n    background: rgba(7, 251, 162, 0.1);\n    color: var(--accent);\n    border-right: 3px solid var(--accent);\n  }\n\n  .sidebar-item:hover {\n    background: rgba(255, 255, 255, 0.03);\n    color: var(--accent);\n  }\n</style>\n\n<div class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  <div class=\"diagonal-bg\" data-kid=\"2\"></div>\n\n  \n  <aside class=\"w-60 h-screen sticky top-0 border-r border-[var(--border)] glass flex flex-col\" data-kid=\"3\">\n    <div class=\"p-6 h-16 flex items-center border-b border-[var(--border)]\" data-kid=\"4\">\n      <div class=\"flex items-center gap-3\" data-kid=\"5\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 1024 1024\" data-kid=\"6\">\n          <path fill=\"#07FBA2\" d=\"M341.647 349.033C349.227 356.485 357.083 363.361 364.808 370.629L440.352 440.857L480.266 478.231C486.224 483.811 495.223 492.746 501.301 497.596C526.384 475.743 556.503 453.025 582.698 432.012L617.69 403.989C620.455 401.764 631.888 391.908 634.031 391.364C635.782 391.624 635.096 391.23 636.216 392.481C636.581 394.874 636.148 402.392 636.054 405.122L635.183 430.743L633.215 489.494C633.056 494.91 633.534 509.174 632.268 513.454C630.851 511.6 631.166 411.271 630.875 399.791C622.573 406.991 614.352 413.194 605.815 420.044L555.984 459.813C539.727 472.734 521.102 489.097 504.194 500.904C535.595 530.538 566.824 560.355 597.878 590.353C623.119 614.832 649.265 641.271 674.852 665.173L673.306 665.532C669.219 661.175 661.527 654.472 656.865 650.166L624.658 620.347L523.666 526.067C516.846 531.305 509.654 537.594 502.778 543.048L427.572 602.973L404.414 621.425C400.726 624.393 392.453 632.874 388.025 631.859C387.282 630.424 387.346 628.074 387.386 626.393C388.086 597.066 389.295 567.657 390.709 538.357C390.911 534.171 391.208 513.055 391.925 510.5C393.513 512.559 392.965 548.945 392.988 554.751L393.547 623.502C435.145 589.56 478.34 555.974 520.352 522.473C515.947 519.071 509.44 512.502 505.048 508.414C492.077 496.267 479.233 483.985 466.52 471.569L368 376.643C358.721 367.759 349.76 358.456 340.352 349.727L341.647 349.033Z\" data-kid=\"7\"></path>\n        </svg>\n        <span class=\"text-xl font-bold tracking-tight text-[var(--accent)]\" data-kid=\"8\">JP-WALLET</span>\n      </div>\n    </div>\n    \n    <nav class=\"flex-1 py-8\" data-kid=\"9\">\n      <ul class=\"space-y-1\" data-kid=\"10\">\n        <li data-kid=\"11\">\n          <a href=\"#\" class=\"sidebar-item nav-item-active flex items-center gap-3 px-6 py-3 transition-colors\" data-kid=\"12\">\n            <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"13\"></i>\n            <span class=\"font-medium\" data-kid=\"14\">Dashboard</span>\n          </a>\n        </li>\n        <li data-kid=\"15\">\n          <a href=\"#\" class=\"sidebar-item flex items-center gap-3 px-6 py-3 text-[var(--text-secondary)] transition-colors\" data-kid=\"16\">\n            <i class=\"ti ti-arrows-left-right text-lg\" data-kid=\"17\"></i>\n            <span class=\"font-medium\" data-kid=\"18\">Transacciones</span>\n          </a>\n        </li>\n        <li data-kid=\"19\">\n          <a href=\"#\" class=\"sidebar-item flex items-center gap-3 px-6 py-3 text-[var(--text-secondary)] transition-colors\" data-kid=\"20\">\n            <i class=\"ti ti-wallet text-lg\" data-kid=\"21\"></i>\n            <span class=\"font-medium\" data-kid=\"22\">Cuentas</span>\n          </a>\n        </li>\n        <li data-kid=\"23\">\n          <a href=\"#\" class=\"sidebar-item flex items-center gap-3 px-6 py-3 text-[var(--text-secondary)] transition-colors\" data-kid=\"24\">\n            <i class=\"ti ti-chart-bar text-lg\" data-kid=\"25\"></i>\n            <span class=\"font-medium\" data-kid=\"26\">Reportes</span>\n          </a>\n        </li>\n        <li data-kid=\"27\">\n          <a href=\"#\" class=\"sidebar-item flex items-center gap-3 px-6 py-3 text-[var(--text-secondary)] transition-colors\" data-kid=\"28\">\n            <i class=\"ti ti-settings text-lg\" data-kid=\"29\"></i>\n            <span class=\"font-medium\" data-kid=\"30\">Configuración</span>\n          </a>\n        </li>\n      </ul>\n    </nav>\n\n    <div class=\"p-6 border-t border-[var(--border)]\" data-kid=\"31\">\n      <div class=\"bg-[var(--surface-2)] rounded-xl p-4 border border-[var(--border)] relative overflow-hidden group\" data-kid=\"32\">\n        <div class=\"absolute -right-4 -bottom-4 w-20 h-20 bg-[var(--accent)] opacity-5 blur-2xl group-hover:opacity-10 transition-opacity\" data-kid=\"33\"></div>\n        <p class=\"text-xs text-[var(--text-tertiary)] uppercase tracking-wider font-bold mb-2\" data-kid=\"34\">Plan Premium</p>\n        <p class=\"text-sm font-medium mb-3\" data-kid=\"35\">Obtené más con Pro</p>\n        <button class=\"w-full py-2 bg-[var(--accent)] text-[#000] font-bold text-xs rounded-lg hover:scale-[0.98] transition-transform\" data-kid=\"36\">MEJORAR</button>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col\" data-kid=\"37\">\n    \n    <header class=\"h-16 sticky top-0 border-b border-[var(--border)] glass z-10 px-8 flex items-center justify-between\" data-kid=\"38\">\n      <h1 class=\"text-lg font-bold\" data-kid=\"39\">Dashboard</h1>\n      \n      <div class=\"flex items-center gap-6\" data-kid=\"40\">\n        \n        <button class=\"w-10 h-10 flex items-center justify-center rounded-lg hover:bg-[var(--surface-2)] transition-colors text-[var(--text-secondary)]\" data-kid=\"41\">\n          <i class=\"ti ti-moon text-xl\" data-kid=\"42\"></i>\n        </button>\n\n        \n        <button class=\"w-10 h-10 relative flex items-center justify-center rounded-lg hover:bg-[var(--surface-2)] transition-colors text-[var(--text-secondary)]\" data-kid=\"43\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"44\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-[var(--accent)] rounded-full border-2 border-[var(--bg)]\" data-kid=\"45\"></span>\n        </button>\n\n        \n        <div class=\"flex items-center gap-3 pl-4 border-l border-[var(--border)] group cursor-pointer\" data-kid=\"46\">\n          <div class=\"text-right\" data-kid=\"47\">\n            <p class=\"text-sm font-bold group-hover:text-[var(--accent)] transition-colors\" data-kid=\"48\">Juan Pérez</p>\n            <p class=\"text-[10px] text-[var(--text-tertiary)] font-bold\" data-kid=\"49\">PREMIUM</p>\n          </div>\n          <div class=\"w-10 h-10 rounded-lg bg-[var(--accent)] flex items-center justify-center font-bold text-[#000] text-sm shadow-lg shadow-[var(--accent)]/20 overflow-hidden\" data-kid=\"50\">\n            <img src=\"https://i.pravatar.cc/100?u=juanperez\" alt=\"Avatar\" class=\"w-full h-full object-cover\" data-kid=\"51\">\n          </div>\n          <i class=\"ti ti-chevron-down text-[var(--text-tertiary)] group-hover:text-[var(--text-primary)] transition-colors\" data-kid=\"52\"></i>\n        </div>\n      </div>\n    </header>\n\n    \n    <section class=\"p-8 flex-1\" data-kid=\"53\">\n      <div class=\"max-w-6xl mx-auto space-y-8\" data-kid=\"54\">\n        \n        <div class=\"relative bg-[var(--surface-1)] rounded-2xl p-8 border border-[var(--border)] overflow-hidden\" data-kid=\"55\">\n          <div class=\"absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[var(--accent)]/5 to-transparent pointer-events-none\" data-kid=\"56\"></div>\n          <div class=\"relative z-1\" data-kid=\"57\">\n            <h2 class=\"text-3xl font-bold mb-2\" data-kid=\"58\">¡Hola, Juan! 👋</h2>\n            <p class=\"text-[var(--text-secondary)] max-w-md\" data-kid=\"59\">Tu resumen financiero está actualizado. Has ahorrado un <span class=\"text-[var(--accent)] font-bold\" data-kid=\"60\">12%</span> más este mes.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"61\">\n          <div class=\"bg-[var(--surface-1)] p-6 rounded-2xl border border-[var(--border)] hover:border-[var(--accent)]/30 transition-all group\" data-kid=\"62\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"63\">\n              <div class=\"w-10 h-10 bg-[var(--accent)]/10 rounded-xl flex items-center justify-center text-[var(--accent)]\" data-kid=\"64\">\n                <i class=\"ti ti-coin text-xl\" data-kid=\"65\"></i>\n              </div>\n              <span class=\"text-xs font-bold text-[var(--success)] flex items-center gap-1\" data-kid=\"66\">\n                <i class=\"ti ti-arrow-up-right\" data-kid=\"67\"></i> +4.2%\n              </span>\n            </div>\n            <p class=\"text-xs text-[var(--text-tertiary)] font-bold uppercase tracking-wider mb-1\" data-kid=\"68\">Balance Total</p>\n            <p class=\"text-2xl font-bold font-mono\" data-kid=\"69\">$24.500,00</p>\n          </div>\n\n          <div class=\"bg-[var(--surface-1)] p-6 rounded-2xl border border-[var(--border)] hover:border-[var(--accent)]/30 transition-all\" data-kid=\"70\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"71\">\n              <div class=\"w-10 h-10 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-400\" data-kid=\"72\">\n                <i class=\"ti ti-arrow-up text-xl\" data-kid=\"73\"></i>\n              </div>\n              <span class=\"text-xs font-bold text-[var(--text-secondary)]\" data-kid=\"74\">Este mes</span>\n            </div>\n            <p class=\"text-xs text-[var(--text-tertiary)] font-bold uppercase tracking-wider mb-1\" data-kid=\"75\">Ingresos</p>\n            <p class=\"text-2xl font-bold font-mono\" data-kid=\"76\">$12.300,00</p>\n          </div>\n\n          <div class=\"bg-[var(--surface-1)] p-6 rounded-2xl border border-[var(--border)] hover:border-[var(--accent)]/30 transition-all\" data-kid=\"77\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"78\">\n              <div class=\"w-10 h-10 bg-red-500/10 rounded-xl flex items-center justify-center text-red-400\" data-kid=\"79\">\n                <i class=\"ti ti-arrow-down text-xl\" data-kid=\"80\"></i>\n              </div>\n              <span class=\"text-xs font-bold text-[var(--danger)] flex items-center gap-1\" data-kid=\"81\">\n                <i class=\"ti ti-alert-circle\" data-kid=\"82\"></i> +$200\n              </span>\n            </div>\n            <p class=\"text-xs text-[var(--text-tertiary)] font-bold uppercase tracking-wider mb-1\" data-kid=\"83\">Gastos</p>\n            <p class=\"text-2xl font-bold font-mono\" data-kid=\"84\">$8.900,00</p>\n          </div>\n        </div>\n\n        \n        <div class=\"bg-[var(--surface-1)] rounded-2xl border border-[var(--border)] overflow-hidden\" data-kid=\"85\">\n          <div class=\"p-6 border-b border-[var(--border)] flex justify-between items-center\" data-kid=\"86\">\n            <h3 class=\"font-bold\" data-kid=\"87\">Actividad Reciente</h3>\n            <button class=\"text-xs font-bold text-[var(--accent)] hover:underline\" data-kid=\"88\">Ver todo</button>\n          </div>\n          <div class=\"p-6\" data-kid=\"89\">\n            <div class=\"flex items-center justify-center h-40 text-[var(--text-tertiary)] italic text-sm\" data-kid=\"90\">\n              <div class=\"text-center\" data-kid=\"91\">\n                <i class=\"ti ti-history text-4xl mb-2 opacity-20\" data-kid=\"92\"></i>\n                <p data-kid=\"93\">Las transacciones aparecerán aquí...</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n</div>",
