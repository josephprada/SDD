      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap');\n\n  :root {\n    --bg: #0F1419;\n    --surface-1: #1A1F26;\n    --surface-2: #242A33;\n    --surface-3: #2F3742;\n    --accent: #07FBA2;\n    --accent-hover: #05D68B;\n    --text-primary: #FAFAFA;\n    --text-secondary: #A1A8B3;\n    --text-tertiary: #6B7280;\n    --danger: #F87171;\n    --success: #34D399;\n    --border: #2F3742;\n    --radius-md: 8px;\n    --radius-lg: 12px;\n    --font-sans: 'Inter Variable', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    padding: 48px;\n  }\n\n  .glass {\n    background: color-mix(in srgb, var(--surface-1) 60%, transparent);\n    backdrop-filter: blur(32px);\n    border: 1px solid var(--border);\n  }\n\n  .btn-primary {\n    background-color: var(--accent);\n    color: #000;\n    font-weight: 600;\n    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .btn-primary:hover:not(:disabled) {\n    transform: translateY(-4px);\n    box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 40%, transparent);\n    background-color: var(--accent-hover);\n  }\n  .btn-primary:active:not(:disabled) {\n    transform: scale(0.97);\n  }\n\n  .btn-secondary {\n    background-color: var(--surface-1);\n    border: 1px solid var(--border);\n    color: var(--text-primary);\n    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .btn-secondary:hover:not(:disabled) {\n    border-color: var(--accent);\n    background-color: var(--surface-2);\n  }\n\n  .input-field {\n    background: var(--surface-2);\n    border: 1px solid var(--border);\n    color: var(--text-primary);\n    transition: border-color 0.2s;\n  }\n  .input-field:focus {\n    border-color: var(--accent);\n    outline: none;\n    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent);\n  }\n\n  .polygon-avatar {\n    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);\n  }\n\n  .spinner-dot {\n    width: 8px;\n    height: 8px;\n    background-color: var(--accent);\n    border-radius: 50%;\n    animation: dot-stagger 1.5s infinite;\n  }\n  @keyframes dot-stagger {\n    0%, 20% { opacity: 0; transform: scale(0.5); }\n    50% { opacity: 1; transform: scale(1); }\n    80%, 100% { opacity: 0; transform: scale(0.5); }\n  }\n\n  .diagonal-bg {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    z-index: -1;\n    background: linear-gradient(135deg, #0F1419 0%, #1A1F26 100%);\n    overflow: hidden;\n  }\n  .diagonal-bg::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -50%;\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(30deg, transparent 40%, color-mix(in srgb, var(--accent) 5%, transparent) 50%, transparent 60%);\n    transform: rotate(-15deg);\n  }\n</style>\n\n<div class=\"diagonal-bg\" data-kid=\"1\"></div>\n\n<div class=\"max-w-6xl mx-auto space-y-16\" data-kid=\"2\">\n  \n  <div class=\"flex items-center justify-between\" data-kid=\"3\">\n    <div data-kid=\"4\">\n      <h1 class=\"text-5xl font-bold tracking-tight text-(--accent)\" style=\"font-family: 'Cal Sans', sans-serif;\" data-kid=\"5\">JP-DS Components</h1>\n      <p class=\"text-(--text-secondary) mt-2\" data-kid=\"6\">Foundational UI elements for JP-WALLET (Dark Theme)</p>\n    </div>\n    <div class=\"glass px-4 py-2 rounded-full flex items-center gap-3\" data-kid=\"7\">\n      <div class=\"w-2 h-2 rounded-full bg-(--accent) animate-pulse\" data-kid=\"8\"></div>\n      <span class=\"text-xs font-mono uppercase tracking-widest text-(--accent)\" data-kid=\"9\">System Active</span>\n    </div>\n  </div>\n\n  \n  <section class=\"space-y-8\" data-kid=\"10\">\n    <h2 class=\"text-xl font-semibold border-l-4 border-(--accent) pl-4\" data-kid=\"11\">Buttons</h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-8\" data-kid=\"12\">\n      \n      <div class=\"space-y-4\" data-kid=\"13\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"14\">Primary</p>\n        <button class=\"btn-primary w-full py-3 rounded-(--radius-md)\" data-kid=\"15\">Default</button>\n        <button class=\"btn-primary w-full py-3 rounded-(--radius-md) opacity-80 shadow-[0_0_15px_rgba(7,251,162,0.3)]\" data-kid=\"16\">Hover State</button>\n        <button class=\"btn-primary w-full py-3 rounded-(--radius-md) scale-95 opacity-90\" data-kid=\"17\">Pressed</button>\n        <button class=\"btn-primary w-full py-3 rounded-(--radius-md) opacity-40 cursor-not-allowed\" data-kid=\"18\">Disabled</button>\n      </div>\n\n      <div class=\"space-y-4\" data-kid=\"19\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"20\">Secondary</p>\n        <button class=\"btn-secondary w-full py-3 rounded-(--radius-md)\" data-kid=\"21\">Outline</button>\n        <button class=\"btn-secondary w-full py-3 rounded-(--radius-md) border-(--accent) bg-(--surface-2)\" data-kid=\"22\">Hover</button>\n        <button class=\"btn-secondary w-full py-3 rounded-(--radius-md) flex items-center justify-center gap-2\" data-kid=\"23\">\n           <div class=\"flex gap-1\" data-kid=\"24\">\n             <div class=\"spinner-dot\" style=\"animation-delay: 0s\" data-kid=\"25\"></div>\n             <div class=\"spinner-dot\" style=\"animation-delay: 0.2s\" data-kid=\"26\"></div>\n             <div class=\"spinner-dot\" style=\"animation-delay: 0.4s\" data-kid=\"27\"></div>\n           </div>\n        </button>\n      </div>\n\n      <div class=\"space-y-4\" data-kid=\"28\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"29\">Success / Error</p>\n        <button class=\"bg-(--success) text-[#000] font-bold w-full py-3 rounded-(--radius-md) flex items-center justify-center gap-2\" data-kid=\"30\">\n          <i class=\"ti ti-check\" data-kid=\"31\"></i> Success\n        </button>\n        <button class=\"bg-(--danger) text-[#000] font-bold w-full py-3 rounded-(--radius-md) flex items-center justify-center gap-2\" data-kid=\"32\">\n          <i class=\"ti ti-alert-triangle\" data-kid=\"33\"></i> Error State\n        </button>\n      </div>\n\n      <div class=\"space-y-4\" data-kid=\"34\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"35\">Special</p>\n        <button class=\"glass w-full py-3 rounded-(--radius-md) text-(--text-primary) hover:border-(--accent) transition-colors\" data-kid=\"36\">\n          Ghost Action\n        </button>\n        <div class=\"flex gap-4\" data-kid=\"37\">\n          <button class=\"w-12 h-12 glass rounded-full flex items-center justify-center hover:text-(--accent) transition-colors\" data-kid=\"38\">\n            <i class=\"ti ti-sun text-xl\" data-kid=\"39\"></i>\n          </button>\n          <button class=\"w-12 h-12 glass rounded-full flex items-center justify-center text-(--accent)\" data-kid=\"40\">\n            <i class=\"ti ti-moon text-xl\" data-kid=\"41\"></i>\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"42\">\n    <h2 class=\"text-xl font-semibold border-l-4 border-(--accent) pl-4\" data-kid=\"43\">Form Inputs</h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"44\">\n      <div class=\"space-y-1\" data-kid=\"45\">\n        <label class=\"text-xs font-medium text-(--text-secondary)\" data-kid=\"46\">Email Address</label>\n        <input type=\"text\" placeholder=\"name@domain.com\" class=\"input-field w-full px-4 py-3 rounded-(--radius-md)\" data-kid=\"47\">\n      </div>\n      <div class=\"space-y-1\" data-kid=\"48\">\n        <label class=\"text-xs font-medium text-(--accent)\" data-kid=\"49\">Focused Input</label>\n        <input type=\"text\" value=\"Active interaction\" class=\"input-field w-full px-4 py-3 rounded-(--radius-md) border-(--accent)\" data-kid=\"50\">\n      </div>\n      <div class=\"space-y-1\" data-kid=\"51\">\n        <label class=\"text-xs font-medium text-(--danger)\" data-kid=\"52\">Error Validation</label>\n        <input type=\"text\" value=\"Invalid value\" class=\"input-field w-full px-4 py-3 rounded-(--radius-md) border-(--danger) text-(--danger)\" data-kid=\"53\">\n        <p class=\"text-[10px] text-(--danger) mt-1\" data-kid=\"54\">Please enter a valid format.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"55\">\n    <h2 class=\"text-xl font-semibold border-l-4 border-(--accent) pl-4\" data-kid=\"56\">Identity & Data</h2>\n    <div class=\"glass p-8 rounded-(--radius-lg) flex flex-wrap items-center gap-12\" data-kid=\"57\">\n      <div class=\"space-y-4\" data-kid=\"58\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"59\">Polygon Avatars</p>\n        <div class=\"flex gap-4\" data-kid=\"60\">\n          <div class=\"w-16 h-16 polygon-avatar bg-(--accent) flex items-center justify-center text-[#000] font-bold text-xl\" data-kid=\"61\">\n            JD\n          </div>\n          <img src=\"https://i.pravatar.cc/100?u=jp\" class=\"w-16 h-16 polygon-avatar border-2 border-(--border)\" data-kid=\"62\">\n          <div class=\"w-12 h-12 polygon-avatar bg-(--surface-3) flex items-center justify-center\" data-kid=\"63\">\n            <i class=\"ti ti-user text-(--text-secondary)\" data-kid=\"64\"></i>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\" data-kid=\"65\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"66\">Financial Typography</p>\n        <div class=\"space-y-1\" data-kid=\"67\">\n          <div class=\"text-3xl font-mono text-(--accent)\" data-kid=\"68\">$45,280.00</div>\n          <div class=\"text-sm font-mono text-(--success)\" data-kid=\"69\">+2.45% <i class=\"ti ti-trending-up\" data-kid=\"70\"></i></div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4 flex-1\" data-kid=\"71\">\n        <p class=\"text-xs font-mono text-(--text-tertiary) uppercase\" data-kid=\"72\">Status & Badges</p>\n        <div class=\"flex flex-wrap gap-2\" data-kid=\"73\">\n          <span class=\"px-3 py-1 bg-(--accent)/10 text-(--accent) rounded-full text-[10px] font-bold border border-(--accent)/20\" data-kid=\"74\">VERIFIED</span>\n          <span class=\"px-3 py-1 bg-(--danger)/10 text-(--danger) rounded-full text-[10px] font-bold border border-(--danger)/20\" data-kid=\"75\">PENDING</span>\n          <span class=\"px-3 py-1 bg-(--text-tertiary)/10 text-(--text-tertiary) rounded-full text-[10px] font-bold border border-(--text-tertiary)/20\" data-kid=\"76\">ARCHIVED</span>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"77\">",
