      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg: #0F1419;\n    --surface-1: #1A1F26;\n    --text-primary: #FAFAFA;\n    --text-secondary: #A1A8B3;\n    --accent: #07FBA2;\n    --accent-dark: #159563;\n    --border: rgba(47, 55, 66, 0.5);\n    --font-sans: 'Inter', system-ui, sans-serif;\n  }\n\n  body {\n    margin: 0;\n    font-family: var(--font-sans);\n    background-color: var(--bg);\n    color: var(--text-primary);\n    -webkit-font-smoothing: antialiased;\n    overflow-x: hidden;\n  }\n\n  .glass {\n    background: rgba(26, 31, 38, 0.7);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--border);\n  }\n\n  .bolt-shadow {\n    filter: drop-shadow(0 0 12px rgba(7, 251, 162, 0.3));\n  }\n\n  .diagonal-bg {\n    position: fixed;\n    top: -10%;\n    right: -20%;\n    width: 100%;\n    height: 120%;\n    background: linear-gradient(135deg, rgba(7, 251, 162, 0.05) 0%, transparent 50%);\n    clip-path: polygon(20% 0%, 100% 0%, 100% 100%, 0% 100%);\n    z-index: -1;\n  }\n\n  .nav-item-active {\n    color: var(--accent);\n  }\n\n  .nav-item-active .pill {\n    background: var(--accent);\n    box-shadow: 0 0 15px rgba(7, 251, 162, 0.4);\n  }\n\n  @keyframes pulse {\n    0%, 100% { transform: scale(1); opacity: 1; }\n    50% { transform: scale(1.05); opacity: 0.9; }\n  }\n\n  .animate-bolt {\n    animation: pulse 3s ease-in-out infinite;\n  }\n</style>\n\n<div class=\"min-h-screen pb-24 relative overflow-hidden\" data-kid=\"1\">\n  <div class=\"diagonal-bg\" data-kid=\"2\"></div>\n\n  \n  <header class=\"fixed top-0 left-0 right-0 z-50 glass border-t-0 border-x-0 h-16 px-5 flex items-center justify-between\" data-kid=\"3\">\n    <div class=\"flex items-center gap-3\" data-kid=\"4\">\n      <img src=\"/api/local/images/public/icon.svg\" alt=\"JP-WALLET\" class=\"w-8 h-8 bolt-shadow\" data-kid=\"5\">\n      <span class=\"font-bold text-lg tracking-tight\" data-kid=\"6\">JP-WALLET</span>\n    </div>\n    \n    <div class=\"flex items-center gap-4\" data-kid=\"7\">\n      <button class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-text-secondary hover:text-accent transition-colors duration-200\" data-kid=\"8\">\n        <i class=\"ti ti-moon-stars text-xl\" data-kid=\"9\"></i>\n      </button>\n      <div class=\"w-9 h-9 rounded-full border border-accent/30 overflow-hidden bg-surface-1 flex items-center justify-center font-bold text-accent text-sm\" data-kid=\"10\">\n        JP\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"pt-20 px-5 space-y-6\" data-kid=\"11\">\n    <div class=\"space-y-1\" data-kid=\"12\">\n      <h1 class=\"text-2xl font-bold\" data-kid=\"13\">Dashboard</h1>\n      <p class=\"text-text-secondary text-sm\" data-kid=\"14\">Bienvenido de nuevo, Juan.</p>\n    </div>\n\n    \n    <div class=\"glass rounded-2xl p-6 relative overflow-hidden group\" data-kid=\"15\">\n      <div class=\"absolute -right-12 -top-12 w-32 h-32 bg-accent/10 rounded-full blur-3xl transition-all duration-500 group-hover:bg-accent/20\" data-kid=\"16\"></div>\n      \n      <div class=\"space-y-4 relative\" data-kid=\"17\">\n        <div class=\"flex justify-between items-start\" data-kid=\"18\">\n          <span class=\"text-text-secondary text-xs font-medium tracking-wider uppercase\" data-kid=\"19\">Saldo Total</span>\n          <i class=\"ti ti-dots-vertical text-text-secondary\" data-kid=\"20\"></i>\n        </div>\n        <div class=\"flex items-baseline gap-1\" data-kid=\"21\">\n          <span class=\"text-3xl font-bold\" data-kid=\"22\">$12.450,00</span>\n          <span class=\"text-accent text-xs font-bold\" data-kid=\"23\">+2.4%</span>\n        </div>\n        <div class=\"flex gap-2 pt-2\" data-kid=\"24\">\n          <button class=\"flex-1 h-10 rounded-lg bg-accent text-bg font-bold text-xs hover:opacity-90 transition-opacity\" data-kid=\"25\">\n            Enviar\n          </button>\n          <button class=\"flex-1 h-10 rounded-lg glass font-bold text-xs\" data-kid=\"26\">\n            Ingresar\n          </button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"space-y-4\" data-kid=\"27\">\n      <div class=\"flex justify-between items-center\" data-kid=\"28\">\n        <h2 class=\"font-bold\" data-kid=\"29\">Transacciones</h2>\n        <button class=\"text-accent text-xs font-medium\" data-kid=\"30\">Ver todas</button>\n      </div>\n\n      <div class=\"space-y-3\" id=\"transaction-list\" data-kid=\"31\">\n        \n        <div class=\"glass rounded-xl p-4 flex items-center justify-between\" data-kid=\"32\">\n          <div class=\"flex items-center gap-3\" data-kid=\"33\">\n            <div class=\"w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-accent\" data-kid=\"34\">\n              <i class=\"ti ti-shopping-cart text-lg\" data-kid=\"35\"></i>\n            </div>\n            <div data-kid=\"36\">\n              <p class=\"text-sm font-semibold\" data-kid=\"37\">Supermercado</p>\n              <p class=\"text-xs text-text-secondary\" data-kid=\"38\">Hoy, 14:20</p>\n            </div>\n          </div>\n          <span class=\"font-bold text-sm\" data-kid=\"39\">-$3.200</span>\n        </div>\n\n        \n        <div class=\"glass rounded-xl p-4 flex items-center justify-between\" data-kid=\"40\">\n          <div class=\"flex items-center gap-3\" data-kid=\"41\">\n            <div class=\"w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center text-accent\" data-kid=\"42\">\n              <i class=\"ti ti-coffee text-lg\" data-kid=\"43\"></i>\n            </div>\n            <div data-kid=\"44\">\n              <p class=\"text-sm font-semibold\" data-kid=\"45\">Starbucks</p>\n              <p class=\"text-xs text-text-secondary\" data-kid=\"46\">Ayer, 09:15</p>\n            </div>\n          </div>\n          <span class=\"font-bold text-sm\" data-kid=\"47\">-$1.450</span>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <nav class=\"fixed bottom-0 left-0 right-0 z-50 h-20 glass border-b-0 border-x-0 px-2\" data-kid=\"48\">\n    <div class=\"h-full flex items-center justify-around\" data-kid=\"49\">\n      <a href=\"#\" class=\"flex flex-col items-center gap-1 nav-item-active\" data-kid=\"50\">\n        <div class=\"pill w-12 h-6 rounded-full flex items-center justify-center mb-1\" data-kid=\"51\">\n          <i class=\"ti ti-smart-home text-lg text-bg\" data-kid=\"52\"></i>\n        </div>\n        <span class=\"text-[10px] font-bold\" data-kid=\"53\">Inicio</span>\n      </a>\n\n      <a href=\"#\" class=\"flex flex-col items-center gap-1 text-text-secondary\" data-kid=\"54\">\n        <i class=\"ti ti-arrows-left-right text-xl\" data-kid=\"55\"></i>\n        <span class=\"text-[10px] font-medium\" data-kid=\"56\">Transac.</span>\n      </a>\n\n      \n      <div class=\"relative -mt-12\" data-kid=\"57\">\n        <button class=\"w-16 h-16 rounded-2xl bg-accent flex items-center justify-center bolt-shadow transform rotate-45 active:scale-95 transition-transform duration-100\" data-kid=\"58\">\n          <div class=\"transform -rotate-45 flex items-center justify-center animate-bolt\" data-kid=\"59\">\n            <img src=\"/api/local/images/public/icon.svg\" alt=\"Add\" class=\"w-10 h-10 brightness-0\" data-kid=\"60\">\n          </div>\n        </button>\n      </div>\n\n      <a href=\"#\" class=\"flex flex-col items-center gap-1 text-text-secondary\" data-kid=\"61\">\n        <i class=\"ti ti-chart-pie text-xl\" data-kid=\"62\"></i>\n        <span class=\"text-[10px] font-medium\" data-kid=\"63\">Reportes</span>\n      </a>\n\n      <a href=\"#\" class=\"flex flex-col items-center gap-1 text-text-secondary\" data-kid=\"64\">\n        <i class=\"ti ti-settings text-xl\" data-kid=\"65\"></i>\n        <span class=\"text-[10px] font-medium\" data-kid=\"66\">Config.</span>\n      </a>\n    </div>\n  </nav>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"67\"></script>\n<script data-kid=\"68\">\n  window.addEventListener('DOMContentLoaded', () => {\n    const tl = gsap.timeline({ defaults: { ease: 'power3.out', duration: 0.6 } });\n    \n    tl.from('header', { y: -20, opacity: 0 })\n      .from('main > div', { y: 20, opacity: 0, stagger: 0.1 }, '-=0.4')\n      .from('#transaction-list > div', { x: -20, opacity: 0, stagger: 0.08 }, '-=0.4')\n      .from('nav', { y: 20, opacity: 0 }, '-=0.6')\n      .from('nav .relative', { scale: 0, rotation: 180, duration: 0.8, ease: 'back.out(1.7)' }, '-=0.4');\n  });\n</script>",
