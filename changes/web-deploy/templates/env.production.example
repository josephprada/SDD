# Variables de build para producción (NO commitear valores reales)
# Copiar a GitHub Secrets o .env.production.local (gitignored)

# Convex — deployment PRODUCCIÓN (HTTPS)
VITE_CONVEX_URL=https://YOUR-PROD-DEPLOYMENT.convex.cloud

# Google OAuth — mismo Client ID que AUTH_GOOGLE_ID en Convex prod
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

