# Convex (raíz del monorepo — Vite lee desde aquí vía envDir)
VITE_CONVEX_URL=http://127.0.0.1:3210
VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# Google OAuth — frontend (mismo Client ID que AUTH_GOOGLE_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth — backend (configurar también con: bunx convex env set AUTH_GOOGLE_ID ...)
# AUTH_GOOGLE_ID y AUTH_GOOGLE_SECRET van en Convex, no en variables VITE_*
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Tras configurar Google, ejecutar:
# bunx convex env set SITE_URL http://localhost:5173
# bunx convex env set AUTH_GOOGLE_ID "<client-id>"
# bunx convex env set AUTH_GOOGLE_SECRET "<secret>"

# JWT para sesiones (@convex-dev/auth) — solo en Convex, no en VITE_*:
# bun run convex:setup-jwt
# Luego reinicia: bunx convex dev
