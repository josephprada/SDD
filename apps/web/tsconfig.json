{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@jp-ds": ["../../packages/jp-ds/src/index.ts"],
      "@jp-ds/*": ["../../packages/jp-ds/src/*"],
      "@app/*": ["./src/*"],
      "@convex/*": ["../../convex/*"]
    }
  },
  "include": ["src", "../../convex/_generated", "../../convex/env.d.ts"],
  "exclude": ["src/sw.ts"]
}
